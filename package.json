{
  "name": "hermes-home-plugin",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:dashboard && npm run build:desktop",
    "build:dashboard": "vite build",
    "build:desktop": "vite build --config vite.desktop.config.ts",
    "install:desktop": "node scripts/install-desktop.mjs",
    "test": "node --experimental-strip-types --test",
    "typecheck": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
